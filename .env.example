# 数据库配置
DB_URL=jdbc:postgresql://localhost:5432/meeting_agent
DB_USERNAME=user
DB_PASSWORD=password

# MiMo-V2.5-ASR API Key
MIMO_API_KEY=your-key-here

# Tavily Web Search API Key (optional, for agent web search capability)
TAVILY_API_KEY=your-key-here

# 文件上传路径
FILE_UPLOAD_DIR=./uploads

# Spring 配置
SPRING_PROFILES_ACTIVE=dev
